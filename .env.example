# ============================================================
# Yuzu Companion — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore — NEVER commit your actual secrets.
# ============================================================

# ── PostgreSQL ─────────────────────────────────────────────
# Connection details (use your own values or reverse tunnel)
PGHOST=<SET_IN_ENV>
PGPORT=<SET_IN_ENV>
PGDATABASE=<SET_IN_ENV>
PGUSER=<SET_IN_ENV>
PGPASSWORD=<SET_IN_ENV>

# ── AI Providers ───────────────────────────────────────────
# Get keys from: https://chutes.ai, https://openrouter.ai, etc.

# Cerebras
CEREBRAS_API_KEY=<SET_IN_ENV>

# Chutes (LLM + Embeddings)
CHUTES_API_KEY=<SET_IN_ENV>

# OpenRouter
OPENROUTER_API_KEY=<SET_IN_ENV>

# ── Encryption ─────────────────────────────────────────────
# Master encryption key (32 bytes hex = 64 chars)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=<SET_IN_ENV>

# ── Ollama (optional, local inference) ─────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Zo MCP Sandbox (remote tools) ─────────────────────────
# Zo Computer access token for MCP tool execution
# Get from: https://yuzu.zo.computer/?t=settings&s=advanced
#   → Create access token in "Access Tokens" section
#
# This gives Yuzuki access to 72+ Zo tools:
#   - File tools: read_file, edit_file, grep_search, list_files
#   - Web tools: web_search, web_research, x_search, maps_search
#   - Browser tools: open_webpage, view_webpage, use_webpage
#   - Zo Space tools: write_space_route, edit_space_route, etc.
#   - Media tools: generate_image, edit_image, transcribe_audio
#   - Agent tools: create_agent, list_agents, list_rules
#   - And more...
#
# Yuzuki will use these tools during her agentic loop to:
#   - Audit code before commits (ruff check via run_bash_command)
#   - Search web for libraries/dependencies
#   - Access her own workspace files
#   - Deploy frontend to Zo Space
ZO_ACCESS_TOKEN=<SET_IN_ENV>
