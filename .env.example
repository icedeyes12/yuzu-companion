# ============================================================
# Yuzu Companion — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore — NEVER commit your actual secrets.
# ============================================================

# ── PostgreSQL ─────────────────────────────────────────────
# Connection via Tailscale reverse proxy (127.0.0.1 = tunnel)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=yuzuki
PGUSER=yuzu_agent          # read-only agent role (SELECT + INSERT only)
PGPASSWORD=YOUR_PASSWORD_HERE

# ── AI Providers ───────────────────────────────────────────
# Get keys from: https://chutes.ai, https://openrouter.ai, etc.

# Cerebras
CEREBRAS_API_KEY=

# Chutes (LLM + Embeddings)
CHUTES_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# ── Encryption ────────────────────────────────────────────
# Master encryption key (32 bytes hex = 64 chars)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=YOUR_64CHAR_HEX_KEY

# ── Ollama (optional, local inference) ────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
