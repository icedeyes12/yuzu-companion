# ============================================================
# Yuzu Companion — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore — NEVER commit your actual secrets.
# ============================================================

# ── PostgreSQL ─────────────────────────────────────────────
# Connection details (use your own values or reverse tunnel)
PGHOST=<SET_IN_ENV>
PGPORT=<SET_IN_ENV>
PGDATABASE=<SET_IN_ENV>
PGUSER=<SET_IN_ENV>
PGPASSWORD=<SET_IN_ENV>

# ── AI Providers ───────────────────────────────────────────
# Get keys from: https://chutes.ai, https://openrouter.ai, etc.

# Cerebras
CEREBRAS_API_KEY=<SET_IN_ENV>

# Chutes (LLM + Embeddings)
CHUTES_API_KEY=<SET_IN_ENV>

# OpenRouter
OPENROUTER_API_KEY=<SET_IN_ENV>

# ── Encryption ────────────────────────────────────────────
# Master encryption key (32 bytes hex = 64 chars)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=<SET_IN_ENV>

# ── Ollama (optional, local inference) ────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── OAuth2 (Phase 2 — multi-tenant auth) ──────────────────
# Google OIDC
OAUTH_GOOGLE_CLIENT_ID=<SET_IN_ENV>
OAUTH_GOOGLE_CLIENT_SECRET=<SET_IN_ENV>
OAUTH_GOOGLE_REDIRECT_URI=<SET_IN_ENV>

# GitHub OAuth
OAUTH_GITHUB_CLIENT_ID=<SET_IN_ENV>
OAUTH_GITHUB_CLIENT_SECRET=<SET_IN_ENV>
OAUTH_GITHUB_REDIRECT_URI=<SET_IN_ENV>

# Shared auth
APP_BASE_URL=<SET_IN_ENV>
SESSION_SECRET=<SET_IN_ENV>
